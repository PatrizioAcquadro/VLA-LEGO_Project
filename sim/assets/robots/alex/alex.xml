                    </default>
                    <default class="alex/wrist/x/right">
                        <joint range="-0.610865 1.8326"/>
                    </default>
                </default>
            </default>
            <default class="alex/gripper">
                <joint axis="0 0 1" range="-2.61799 2.61799"
                       armature="0.01" damping="0.3" frictionloss="0.05"/>
                <position forcerange="-20 20" kp="15"/>
            </default>
            <default class="alex/visual">
                <geom contype="0" conaffinity="0" group="1" type="mesh"/>
            </default>
            <default class="alex/collision">
                <geom group="3" contype="1" conaffinity="1" rgba="0 1 0 0.3"
                      solref="0.005 1.0" solimp="0.9 0.95 0.001 0.5 2"/>
