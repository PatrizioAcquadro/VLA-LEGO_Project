                                                      class="alex/ezgripper/collision"/>
                                                <site name="right_tool_frame" pos="0.073 0 0"
                                                      type="sphere" size="0.005"
                                                      rgba="1 1 0 0.5" group="4"/>

                                                <!-- Finger 1 (primary, actuated) -->
                                                <body name="right_finger1_l1" pos="0.073 0.03 0">
                                                    <inertial pos="0.026 0 0" mass="0.025"
                                                              diaginertia="5e-06 2e-05 2e-05"/>
                                                    <joint name="right_knuckle_palm_l1_1"
                                                           class="alex/ezgripper/knuckle"/>
                                                    <geom mesh="ezgripper_finger_l1"
                                                          class="alex/ezgripper/visual"/>
                                                    <geom name="right_finger1_l1_col" type="box"
                                                          size="0.026 0.012 0.008" pos="0.026 0 0"
                                                          class="alex/ezgripper/collision"/>
                                                    <body name="right_finger1_l2" pos="0.052 0 0">
                                                        <inertial pos="0.02 0 0" mass="0.025"
                                                                  diaginertia="4e-06 1.5e-05 1.5e-05"/>
                                                        <joint name="right_knuckle_l1_l2_1"
                                                               class="alex/ezgripper/knuckle"/>
                                                        <geom mesh="ezgripper_finger_l2"
                                                              class="alex/ezgripper/visual"/>
                                                        <geom name="right_finger1_pad" type="box"
                                                              size="0.025 0.015 0.008" pos="0.02 0 0"
                                                              class="alex/ezgripper/collision"/>
                                                    </body>
                                                </body>

                                                <!-- Finger 2 (coupled to finger 1) -->
                                                <body name="right_finger2_l1" pos="0.073 -0.03 0">
                                                    <inertial pos="0.026 0 0" mass="0.025"
                                                              diaginertia="5e-06 2e-05 2e-05"/>
                                                    <joint name="right_knuckle_palm_l1_2"
                                                           class="alex/ezgripper/knuckle"/>
                                                    <geom mesh="ezgripper_finger_l1"
                                                          class="alex/ezgripper/visual"/>
                                                    <geom name="right_finger2_l1_col" type="box"
                                                          size="0.026 0.012 0.008" pos="0.026 0 0"
                                                          class="alex/ezgripper/collision"/>
                                                    <body name="right_finger2_l2" pos="0.052 0 0">
                                                        <inertial pos="0.02 0 0" mass="0.025"
                                                                  diaginertia="4e-06 1.5e-05 1.5e-05"/>
                                                        <joint name="right_knuckle_l1_l2_2"
                                                               class="alex/ezgripper/knuckle"/>
                                                        <geom mesh="ezgripper_finger_l2"
                                                              class="alex/ezgripper/visual"/>
                                                        <geom name="right_finger2_pad" type="box"
                                                              size="0.025 0.015 0.008" pos="0.02 0 0"
                                                              class="alex/ezgripper/collision"/>
                                                    </body>
                                                </body>
                                            </body>
                                        </body>
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <position class="alex/spine" name="spine_z" joint="spine_z"/>
        <position class="alex/shoulder/y" name="left_shoulder_y" joint="left_shoulder_y"/>
        <position class="alex/shoulder/x" name="left_shoulder_x" joint="left_shoulder_x"/>
        <position class="alex/shoulder/z" name="left_shoulder_z" joint="left_shoulder_z"/>
        <position class="alex/elbow" name="left_elbow" joint="left_elbow_y"/>
        <position class="alex/wrist" name="left_wrist_z" joint="left_wrist_z"/>
        <position class="alex/wrist" name="left_wrist_x" joint="left_wrist_x"/>
        <position class="alex/gripper" name="left_gripper_z" joint="left_gripper_z"/>
        <position class="alex/shoulder/y" name="right_shoulder_y" joint="right_shoulder_y"/>
        <position class="alex/shoulder/x" name="right_shoulder_x" joint="right_shoulder_x"/>
        <position class="alex/shoulder/z" name="right_shoulder_z" joint="right_shoulder_z"/>
        <position class="alex/elbow" name="right_elbow" joint="right_elbow_y"/>
        <position class="alex/wrist" name="right_wrist_z" joint="right_wrist_z"/>
        <position class="alex/wrist" name="right_wrist_x" joint="right_wrist_x"/>
        <position class="alex/gripper" name="right_gripper_z" joint="right_gripper_z"/>
        <!-- EZGripper actuators: one per hand (Phase 1.1.3) -->
        <position class="alex/ezgripper/knuckle" name="left_ezgripper"
                  joint="left_knuckle_palm_l1_1"/>
        <position class="alex/ezgripper/knuckle" name="right_ezgripper"
                  joint="right_knuckle_palm_l1_1"/>
    </actuator>

    <sensor>
        <framepos name="left_ee_pos" objtype="site" objname="left_ee_site"/>
        <framequat name="left_ee_quat" objtype="site" objname="left_ee_site"/>
        <framepos name="right_ee_pos" objtype="site" objname="right_ee_site"/>
        <framequat name="right_ee_quat" objtype="site" objname="right_ee_site"/>
        <!-- EZGripper tool frame sensors (Phase 1.1.3) -->
        <framepos name="left_tool_pos" objtype="site" objname="left_tool_frame"/>
        <framequat name="left_tool_quat" objtype="site" objname="left_tool_frame"/>
        <framepos name="right_tool_pos" objtype="site" objname="right_tool_frame"/>
        <framequat name="right_tool_quat" objtype="site" objname="right_tool_frame"/>
    </sensor>

    <contact>
        <!-- Exclude adjacent body pairs (geometrically overlapping) -->
        <exclude body1="base_link" body2="torso"/>
        <exclude body1="torso" body2="left_shoulder_y"/>
        <exclude body1="torso" body2="right_shoulder_y"/>
        <exclude body1="torso" body2="neck_z"/>
        <exclude body1="neck_z" body2="head"/>
        <!-- Left arm chain: adjacent pairs -->
        <exclude body1="left_shoulder_y" body2="left_shoulder_x"/>
        <exclude body1="left_shoulder_x" body2="left_shoulder_z"/>
        <exclude body1="left_shoulder_z" body2="left_elbow_y"/>
        <exclude body1="left_elbow_y" body2="left_wrist_z"/>
        <exclude body1="left_wrist_z" body2="left_wrist_x"/>
        <exclude body1="left_wrist_x" body2="left_gripper"/>
        <!-- Left arm chain: 2-link-apart pairs (geometrically close) -->
        <exclude body1="left_shoulder_y" body2="left_shoulder_z"/>
        <exclude body1="left_shoulder_z" body2="left_wrist_z"/>
        <exclude body1="left_elbow_y" body2="left_wrist_x"/>
        <exclude body1="left_wrist_z" body2="left_gripper"/>
        <!-- Right arm chain: adjacent pairs -->
        <exclude body1="right_shoulder_y" body2="right_shoulder_x"/>
        <exclude body1="right_shoulder_x" body2="right_shoulder_z"/>
        <exclude body1="right_shoulder_z" body2="right_elbow_y"/>
        <exclude body1="right_elbow_y" body2="right_wrist_z"/>
        <exclude body1="right_wrist_z" body2="right_wrist_x"/>
        <exclude body1="right_wrist_x" body2="right_gripper"/>
        <!-- Right arm chain: 2-link-apart pairs (geometrically close) -->
        <exclude body1="right_shoulder_y" body2="right_shoulder_z"/>
        <exclude body1="right_shoulder_z" body2="right_wrist_z"/>
        <exclude body1="right_elbow_y" body2="right_wrist_x"/>
        <exclude body1="right_wrist_z" body2="right_gripper"/>
        <!-- Left EZGripper self-collision exclusions (Phase 1.1.3) -->
        <exclude body1="left_gripper" body2="left_ezgripper_palm"/>
        <exclude body1="left_ezgripper_palm" body2="left_finger1_l1"/>
        <exclude body1="left_ezgripper_palm" body2="left_finger2_l1"/>
        <exclude body1="left_finger1_l1" body2="left_finger1_l2"/>
        <exclude body1="left_finger2_l1" body2="left_finger2_l2"/>
        <exclude body1="left_finger1_l1" body2="left_finger2_l1"/>
        <!-- Right EZGripper self-collision exclusions -->
        <exclude body1="right_gripper" body2="right_ezgripper_palm"/>
        <exclude body1="right_ezgripper_palm" body2="right_finger1_l1"/>
        <exclude body1="right_ezgripper_palm" body2="right_finger2_l1"/>
        <exclude body1="right_finger1_l1" body2="right_finger1_l2"/>
        <exclude body1="right_finger2_l1" body2="right_finger2_l2"/>
        <exclude body1="right_finger1_l1" body2="right_finger2_l1"/>
    </contact>

    <!-- EZGripper underactuation coupling (Phase 1.1.3) -->
    <!-- All 4 finger joints per hand driven by single actuator via 1:1 equality -->
    <equality>
        <!-- Left: finger2 mimics finger1, L2 joints coupled to palm-L1 -->
        <joint joint1="left_knuckle_palm_l1_2" joint2="left_knuckle_palm_l1_1"
               polycoef="0 1 0 0 0"/>
        <joint joint1="left_knuckle_l1_l2_1" joint2="left_knuckle_palm_l1_1"
               polycoef="0 1 0 0 0"/>
        <joint joint1="left_knuckle_l1_l2_2" joint2="left_knuckle_palm_l1_1"
               polycoef="0 1 0 0 0"/>
        <!-- Right: same coupling -->
        <joint joint1="right_knuckle_palm_l1_2" joint2="right_knuckle_palm_l1_1"
               polycoef="0 1 0 0 0"/>
        <joint joint1="right_knuckle_l1_l2_1" joint2="right_knuckle_palm_l1_1"
               polycoef="0 1 0 0 0"/>
        <joint joint1="right_knuckle_l1_l2_2" joint2="right_knuckle_palm_l1_1"
               polycoef="0 1 0 0 0"/>
    </equality>

</mujoco>
