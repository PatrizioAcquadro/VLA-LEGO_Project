<mujoco model="alex_upper_body">
    <!--
        Alex V1 Upper-Body Fixed-Base Robot Model (Phase 1.1.1 + 1.1.2 + 1.1.3)

        Source: ihmc-alex-sdk commit be25a395e35238bc6385a58bcc50aa047d936a25
        Base file: alex_v1_full_body_mjx.xml

        Modifications from source:
        - Removed lower body (12 leg joints)
        - Removed freejoint (fixed base at table height)
        - Fixed neck joints (NECK_Z, NECK_Y removed — head is static)
        - Added GRIPPER_Z joints (exist in URDF, missing from source MJCF)
        - Added collision geoms (capsules/boxes) for all upper-body links
        - Added EE sites (left_ee_site, right_ee_site)
        - Added robot camera (robot_cam on head)
        - Added self-collision exclusions for adjacent body pairs
        - (1.1.3) Integrated SAKE EZGripper Gen2 end-effectors on both arms
        - (1.1.3) Added equality constraints for underactuated finger coupling
        - (1.1.3) Added tool frame sites (left_tool_frame, right_tool_frame)

        Joints (23 = 15 arm + 8 EZGripper):
          spine_z
          left_shoulder_y, left_shoulder_x, left_shoulder_z, left_elbow_y,
          left_wrist_z, left_wrist_x, left_gripper_z,
          left_knuckle_palm_l1_1, left_knuckle_l1_l2_1,
          left_knuckle_palm_l1_2, left_knuckle_l1_l2_2
          right_shoulder_y, right_shoulder_x, right_shoulder_z, right_elbow_y,
          right_wrist_z, right_wrist_x, right_gripper_z,
          right_knuckle_palm_l1_1, right_knuckle_l1_l2_1,
          right_knuckle_palm_l1_2, right_knuckle_l1_l2_2

        Actuators (17 = 15 arm + 2 EZGripper):
          15 arm position actuators + left_ezgripper + right_ezgripper
    -->

    <compiler angle="radian" eulerseq="XYZ" autolimits="true"
              balanceinertia="true"/>

    <option iterations="50" ls_iterations="10" timestep="0.002" integrator="implicitfast">
        <flag energy="enable"/>
    </option>

    <default>
        <default class="alex">
            <joint damping="2" frictionloss="0.3"/>
            <position inheritrange="1"/>
            <default class="alex/spine">
                <joint axis="0 0 1" range="-0.5235987756 0.5235987756"
                       armature="0.01" damping="2.0" frictionloss="0.3"/>
                <position forcerange="-150 150" kp="112"/>
            </default>
            <default class="alex/shoulder">
                <default class="alex/shoulder/y">
                    <joint axis="0 1 0" range="-3.141592 1.22173"
                           armature="0.01" damping="2.0" frictionloss="0.3"/>
                    <position forcerange="-150 150" kp="112.5"/>
                </default>
                <default class="alex/shoulder/x">
                    <joint axis="1 0 0" armature="0.01" damping="2.0" frictionloss="0.3"/>
                    <position forcerange="-100 100" kp="75"/>
                    <default class="alex/shoulder/x/left">
                        <joint range="-0.349066 2.79253"/>
                    </default>
                    <default class="alex/shoulder/x/right">
                        <joint range="-2.79253 0.349066"/>
                    </default>
                </default>
                <default class="alex/shoulder/z">
                    <joint axis="0 0 1" armature="0.01" damping="1.5" frictionloss="0.2"/>
                    <position forcerange="-80 80" kp="60"/>
                    <default class="alex/shoulder/z/left">
                        <joint range="-1.91986 1.22173"/>
                    </default>
                    <default class="alex/shoulder/z/right">
                        <joint range="-1.22173 1.91986"/>
                    </default>
                </default>
            </default>
            <default class="alex/elbow">
                <joint axis="0 1 0" range="-2.35619 0.174532925"
                       armature="0.01" damping="1.5" frictionloss="0.2"/>
                <position forcerange="-80 80" kp="60"/>
            </default>
            <default class="alex/wrist">
                <position forcerange="-20 20" kp="15"/>
                <default class="alex/wrist/z">
                    <joint axis="0 0 1" range="-2.61799 2.61799"
